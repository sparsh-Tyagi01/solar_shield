# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# Model Paths
MODEL_PATH=./models
DATA_PATH=./data

# Data Sources
NASA_OMNI_URL=https://omniweb.gsfc.nasa.gov/cgi/nx1.cgi
NOAA_GOES_URL=https://services.swpc.noaa.gov/json/goes

# Satellite Tracking API (N2YO)
# Get your free API key at: https://www.n2yo.com/api/
# Free tier: 1000 requests/hour
N2YO_API_KEY=YOUR_API_KEY_HERE

# AI Chatbot (Google Gemini)
# Get your free API key at: https://makersuite.google.com/app/apikey
# Or: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Model Training
TRAIN_TEST_SPLIT=0.8
RANDOM_SEED=42

# Real-time Updates
UPDATE_INTERVAL=60
